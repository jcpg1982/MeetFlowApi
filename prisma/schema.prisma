generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String           @id @default(uuid())
  email            String           @unique
  alias            String?           @unique
  password         String
  name             String
  photo            String?
  bio              String?
  callPrice        Float            @default(0.0)
  fcmToken         String?
  refreshToken     String?
  sessionId        String?
  lastDeviceId     String?
  lastDeviceName   String?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
  sentRequests     MeetingRequest[] @relation("SentRequests")
  receivedRequests MeetingRequest[] @relation("ReceivedRequests")
  videos           Video[]
  interactions     VideoInteraction[]
  followers        Follow[]         @relation("Followers")
  following        Follow[]         @relation("Following")
  favorites        FavoriteVideo[]
  likes            Like[]
  sentMessages     Message[]        @relation("SentMessages")
  receivedMessages Message[]        @relation("ReceivedMessages")
}

model MeetingRequest {
  id          String   @id @default(uuid())
  senderId    String
  receiverId  String
  status      String   @default("PENDING") // PENDING, ACCEPTED, DECLINED, COMPLETED
  scheduledAt DateTime?
  price       Float    @default(0.0)
  createdAt   DateTime @default(now())
  
  sender      User     @relation("SentRequests", fields: [senderId], references: [id])
  receiver    User     @relation("ReceivedRequests", fields: [receiverId], references: [id])
}

model Video {
  id           String   @id @default(uuid())
  userId       String
  videoUrl     String
  thumbnailUrl String?
  title        String?
  description  String?
  viewCount    Int      @default(0)
  likeCount    Int      @default(0)
  createdAt    DateTime @default(now())

  user         User               @relation(fields: [userId], references: [id])
  interactions VideoInteraction[]
  favorites    FavoriteVideo[]
  likes        Like[]
}

model VideoInteraction {
  id           String   @id @default(uuid())
  videoId      String
  userId       String?
  watchTime    Int      // milliseconds
  isCompleted  Boolean
  createdAt    DateTime @default(now())

  video        Video    @relation(fields: [videoId], references: [id])
  user         User?    @relation(fields: [userId], references: [id])
}

model Follow {
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower    User     @relation("Following", fields: [followerId], references: [id])
  following   User     @relation("Followers", fields: [followingId], references: [id])

  @@id([followerId, followingId])
}

model FavoriteVideo {
  id        String   @id @default(uuid())
  videoId   String
  userId    String
  createdAt DateTime @default(now())

  video     Video    @relation(fields: [videoId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([videoId, userId])
}

model Like {
  id        String   @id @default(uuid())
  videoId   String
  userId    String
  createdAt DateTime @default(now())

  video     Video    @relation(fields: [videoId], references: [id])
  user      User     @relation(fields: [userId], references: [id])

  @@unique([videoId, userId])
}

model CallLog {
  id         String   @id @default(uuid())
  callerId   String
  receiverId String
  status     String   // MADE, ANSWERED, DECLINED, ENDED, BUSY, MISSED
  isIncoming Boolean
  durationSeconds Int?
  createdAt  DateTime @default(now())
}

model Message {
  id              String   @id @default(uuid())
  senderId        String
  receiverId      String
  type            String   // TEXT, PHOTO, VIDEO, AUDIO
  content         String?  // Text content if type is TEXT
  mediaUrl        String?  // Cloudinary URL if PHOTO, VIDEO, or AUDIO
  durationSeconds Int?     // Duration in seconds for audio/video notes
  status          String   @default("SENT") // SENT, DELIVERED, READ
  createdAt       DateTime @default(now())

  sender          User     @relation("SentMessages", fields: [senderId], references: [id])
  receiver        User     @relation("ReceivedMessages", fields: [receiverId], references: [id])
}



